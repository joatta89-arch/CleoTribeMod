		<workAmount>2000</workAmount>
		
		<skillRequirements>
			<Medicine>3</Medicine>
		</skillRequirements>
		
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>CuriosityBot_TribalEye</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		
		<fixedIngredientFilter>
			<thingDefs>
				<li>CuriosityBot_TribalEye</li>
			</thingDefs>
		</fixedIngredientFilter>
		
		<appliedOnFixedBodyParts>
			<li>Eye</li>
		</appliedOnFixedBodyParts>
		
		<addsHediff>CuriosityBot_TribalEye</addsHediff>
	</RecipeDef>

