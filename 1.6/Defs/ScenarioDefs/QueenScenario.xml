<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ScenarioDef>
		<defName>Cleo_QueenSuccession</defName>
		<scenario>
			<name>부족의 여왕</name>
			<summary>부족의 여왕 계승</summary>
			<description>부족간 대전쟁 끝에 당신의 부족은 패배하였습니다. 당신은 납치당했고, 살아남은 클레오 부족의 생존자입니다. 패배를 딛고 일어나 새로운 여왕이 될 지, 좌절 끝에 결국 사라질지는 당신의 손에 달렸습니다.</description>
			<playerFaction>
				<def>PlayerFaction</def>
				<factionDef>Cleo_PlayerTribe</factionDef>
			</playerFaction>
			<surfaceLayer>
				<def>SurfaceLayerFixed</def>
				<layer>Surface</layer>
				<settingsDef>Surface</settingsDef>
				<hide>True</hide>
				<tag>Surface</tag>
				<connections>
					<li>
						<tag>OrbitZoomOut</tag>
					</li>
				</connections>
			</surfaceLayer>
			<parts>
				<li Class="ScenPart_ConfigPage_ConfigureStartingPawns_Xenotypes">
					<def>ConfigurePawnsXenotypes</def>
					<pawnChoiceCount>1</pawnChoiceCount>
					<xenotypeCounts>
						<li>
							<requiredAtStart>True</requiredAtStart>
							<xenotype>Cleo_TribalQueen</xenotype>
							<allowedDevelopmentalStages>Adult</allowedDevelopmentalStages>
							<description>생존자</description>
						</li>
					</xenotypeCounts>
				</li>
				<li Class="ScenPart_PlayerPawnsArriveMethod">
					<def>PlayerPawnsArriveMethod</def>
				</li>
				<li Class="ScenPart_GameStartDialog">
					<def>GameStartDialog</def>
					<text>새로운 시대를 열어라. 운명은 당신의 손에 달려있다.</text>
					<closeSound>GameStartSting</closeSound>
				</li>
				<li Class="ScenPart_StartingAnimal">
					<def>StartingAnimal</def>
					<animalKind>Panther</animalKind>
					<count>1</count>
					<bondToRandomPlayerPawnChance>0.5</bondToRandomPlayerPawnChance>
				</li>
				<li Class="ScenPart_StartingThing_Defined">
					<def>StartingThing_Defined</def>
					<thingDef>Silver</thingDef>
					<count>500</count>
				</li>
				<li Class="ScenPart_StartingThing_Defined">
					<def>StartingThing_Defined</def>
					<thingDef>Pemmican</thingDef>
					<count>600</count>
				</li>
				<li Class="ScenPart_StartingThing_Defined">
					<def>StartingThing_Defined</def>
					<thingDef>MedicineHerbal</thingDef>
					<count>20</count>
				</li>
				<li Class="ScenPart_StartingThing_Defined">
					<def>StartingThing_Defined</def>
					<thingDef>WoodLog</thingDef>
					<count>500</count>
				</li>
				<li Class="ScenPart_StartingThing_Defined">
					<def>StartingThing_Defined</def>
					<thingDef>MeleeWeapon_Ikwa</thingDef>
					<stuff>Jade</stuff>
					<quality>Legendary</quality>
				</li>
				<li Class="ScenPart_CreateQuest">
					<def>CreateQuest</def>
					<questDef>CuriosityBot_Quest_SummonBokbok</questDef>
				</li>
				<li Class="ScenPart_CreateIncident">
					<def>CreateIncident</def>
					<incident>WildManWandersIn</incident>
					<intervalDays>48.9322205</intervalDays>
					<minDays>10</minDays>
					<maxDays>25</maxDays>
					<repeat>True</repeat>
					<occurTick>924922.625</occurTick>
				</li>
				<li Class="ScenPart_StartingResearch">
					<def>StartingResearch</def>
					<project>CuriosityBot_Basic</project>
				</li>
				<li Class="ScenPart_StartingResearch">
					<def>StartingResearch</def>
					<project>ComplexFurniture</project>
				</li>
				<li Class="ScenPart_StartingResearch">
					<def>StartingResearch</def>
					<project>Stonecutting</project>
				</li>
				<li Class="ScenPart_PawnFilter_Age">
					<def>PawnFilter_Age</def>
					<allowedAgeRange>18~21</allowedAgeRange>
				</li>
				<li Class="ScenPart_Naked">
					<def>Naked</def>
					<chance>1</chance>
					<context>PlayerStarter</context>
				</li>
			</parts>
		</scenario>
	</ScenarioDef>
</Defs>